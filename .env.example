# HiggsHole configuration
#
# Copy to .env and edit. Every value below is optional except an API key.
# .env is gitignored — never commit your real keys.

# --- credentials --------------------------------------------------------
# Get a key at https://openrouter.ai/keys
#
# STRONGLY RECOMMENDED: set a credit limit on the key in the OpenRouter
# dashboard. That limit is enforced provider-side and is the only spend guard
# that cannot be defeated by a bug in this application.
HIGGSHOLE_OPENROUTER_API_KEY=

# Optional: use separate keys per media type, so video spend can be capped
# independently at the provider. Both fall back to the key above.
#HIGGSHOLE_OPENROUTER_API_KEY_IMAGE=
#HIGGSHOLE_OPENROUTER_API_KEY_VIDEO=

# --- storage ------------------------------------------------------------
# Generated media. Safe to point at a large disk or a shared directory.
#HIGGSHOLE_MEDIA_ROOT=~/.local/share/higgshole/media

# Database: generation index, spend ledger, and stored keys.
# Keep this OUT of any directory you export over a file-sharing protocol.
#HIGGSHOLE_DB_PATH=~/.local/state/higgshole/higgshole.db

# --- network ------------------------------------------------------------
# There is no authentication. Changing this exposes the app to your network.
#HIGGSHOLE_BIND_HOST=127.0.0.1
#HIGGSHOLE_BIND_PORT=8077

# --- spend control ------------------------------------------------------
# Local daily cap in USD, over a UTC calendar day. Unset means no cap.
#HIGGSHOLE_DAILY_CAP_USD=10.00

# Cost cannot be estimated up front for some models (token-priced video in
# particular). Those jobs reserve this amount against the cap instead, and
# reconcile to the real cost on completion.
#HIGGSHOLE_MAX_JOB_COST_USD=2.00

# Concurrent generation ceiling.
#HIGGSHOLE_MAX_IN_FLIGHT=3

# --- job handling -------------------------------------------------------
#HIGGSHOLE_JOB_TIMEOUT_MINUTES=30
#HIGGSHOLE_POLL_INTERVAL_SECONDS=5
#HIGGSHOLE_MAX_RETRIES=3

# --- catalogue ----------------------------------------------------------
# Model capabilities and pricing are fetched from OpenRouter and cached.
#HIGGSHOLE_CATALOG_TTL_HOURS=24

# --- advanced -----------------------------------------------------------
# How reference images are sent to the provider. See spec section 2.8.
#HIGGSHOLE_REFERENCE_TRANSPORT=data_uri

# Enables the live smoke test, which performs one real, paid generation.
#HIGGSHOLE_LIVE_TESTS=1
